# Обработчики для одобрения/отклонения заявок
@dp.callback_query(F.data.startswith("approve_"))
async def approve_application(callback: CallbackQuery):
    """Одобрение заявки"""
    if not is_bot_admin(callback.from_user.id):
        await callback.answer("❌ Нет прав!")
        return
    
    _, app_type, app_id = callback.data.split("_", 2)
    
    # Определяем словарь с заявками
    pending_dict = {
        "norm": pending_norms,
        "promotion": pending_promotions,
        "extra": pending_extra_works,
        "inactive": pending_inactives
    }.get(app_type)
    
    if not pending_dict or app_id not in pending_dict:
        await callback.message.edit_text("❌ Заявка не найдена или уже обработана")
        await callback.answer()
        return
    
    app_data = pending_dict[app_id]
    user_id = app_data['user_id']
    
    # Начисляем баллы в зависимости от типа заявки
    if app_type == "norm":
        users_db[user_id]['points'] = users_db[user_id].get('points', 0) + 20
        users_db[user_id]['online'] = users_db[user_id].get('online', 0) + 50
        users_db[user_id]['answers'] = users_db[user_id].get('answers', 0) + 50
        await bot.send_message(user_id, "✅ **Ваша норма одобрена!**\n➕ Начислено 20 баллов", parse_mode="Markdown")
    
    elif app_type == "promotion":
        users_db[user_id]['points'] = users_db[user_id].get('points', 0) + 30
        await bot.send_message(user_id, "✅ **Ваше повышение одобрено!**\n➕ Начислено 30 баллов", parse_mode="Markdown")
    
    elif app_type == "extra":
        users_db[user_id]['points'] = users_db[user_id].get('points', 0) + 15
        await bot.send_message(user_id, "✅ **Ваши доп баллы одобрены!**\n➕ Начислено 15 баллов", parse_mode="Markdown")
    
    elif app_type == "inactive":
        await bot.send_message(
            user_id, 
            f"✅ **Ваш неактив одобрен!**\n⏳ Дней: {app_data['days']}\n📅 До: {(datetime.now() + timedelta(days=app_data['days'])).strftime('%d.%m.%Y')}",
            parse_mode="Markdown"
        )
    
    # Удаляем заявку
    del pending_dict[app_id]
    
    await callback.message.edit_text(f"✅ Заявка одобрена!\n\n{callback.message.caption if callback.message.caption else ''}")
    await callback.answer("✅ Одобрено!")

@dp.callback_query(F.data.startswith("reject_"))
async def reject_application_start(callback: CallbackQuery, state: FSMContext):
    """Начало отклонения заявки (запрос причины)"""
    if not is_bot_admin(callback.from_user.id):
        await callback.answer("❌ Нет прав!")
        return
    
    _, app_type, app_id = callback.data.split("_", 2)
    
    # Сохраняем данные в состояние
    await state.update_data(
        app_type=app_type,
        app_id=app_id,
        original_message=callback.message
    )
    
    await callback.message.answer("📝 **Напишите причину отклонения:**", parse_mode="Markdown")
    await state.set_state(AdminReviewStates.waiting_for_rejection_reason)
    await callback.answer()

@dp.message(AdminReviewStates.waiting_for_rejection_reason)
async def process_rejection_reason(message: types.Message, state: FSMContext):
    """Обработка причины отклонения"""
    data = await state.get_data()
    app_type = data.get('app_type')
    app_id = data.get('app_id')
    original_message = data.get('original_message')
    reason = message.text
    
    # Определяем словарь с заявками
    pending_dict = {
        "norm": pending_norms,
        "promotion": pending_promotions,
        "extra": pending_extra_works,
        "inactive": pending_inactives
    }.get(app_type)
    
    if not pending_dict or app_id not in pending_dict:
        await message.answer("❌ Заявка не найдена или уже обработана")
        await state.clear()
        return
    
    app_data = pending_dict[app_id]
    user_id = app_data['user_id']
    
    # Отправляем уведомление пользователю
    await bot.send_message(
        user_id,
        f"❌ **Ваша заявка отклонена**\n📝 Причина: {reason}",
        parse_mode="Markdown"
    )
    
    # Удаляем заявку
    del pending_dict[app_id]
    
    # Обновляем сообщение админа
    try:
        await original_message.edit_text(
            f"❌ Заявка отклонена!\nПричина: {reason}\n\n{original_message.caption if original_message.caption else ''}"
        )
    except:
        pass
    
    await message.answer("✅ Заявка отклонена, уведомление отправлено пользователю")
    await state.clear()

